<Window x:Class="DiskSpaceInspector.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:DiskSpaceInspector.App.Controls"
        xmlns:vm="clr-namespace:DiskSpaceInspector.App.ViewModels"
        mc:Ignorable="d"
        Title="Disk Space Inspector" Height="920" Width="1540" MinHeight="760" MinWidth="1180"
        Background="{StaticResource AppBg}" Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource AppFontFamily}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="78"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource RailBg}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="18,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="Disk Space Inspector" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Windows storage workbench" Foreground="{StaticResource MutedBrush}"/>
                </StackPanel>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Volumes}"
                          SelectedItem="{Binding SelectedVolume}"
                          Height="34"
                          VerticalAlignment="Center"
                          Margin="0,0,14,0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <WrapPanel Grid.Column="2" VerticalAlignment="Center">
                    <Button Content="Refresh" Command="{Binding RefreshDrivesCommand}"/>
                    <Button Content="Load latest" Command="{Binding LoadLatestCommand}"/>
                    <Button Content="Load demo" Command="{Binding LoadDemoCommand}"/>
                    <Button Content="Scan selected" Command="{Binding ScanSelectedCommand}" Background="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"/>
                    <Button Content="Scan all" Command="{Binding ScanAllCommand}"/>
                    <Button Content="Pause" Command="{Binding PauseScanCommand}"/>
                    <Button Content="Resume" Command="{Binding ResumeScanCommand}"/>
                    <Button Content="Cancel" Command="{Binding CancelScanCommand}" Background="#3A2326" BorderBrush="{StaticResource DangerBrush}"/>
                </WrapPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox Width="210" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Global search by name, path, or extension" Margin="0,0,12,0"/>
                    <Border Width="132"
                            Background="{StaticResource SurfaceLowBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="9,6">
                        <TextBlock Text="{Binding LocalAdvisorStatusText}" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    TabStripPlacement="Left"
                    SelectedIndex="{Binding SelectedWorkspaceIndex, Mode=TwoWay}"
                    Background="{StaticResource AppBg}"
                    BorderThickness="0">
            <TabItem Header="Overview">
                <Grid Background="{StaticResource AppBg}" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="182"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.15*"/>
                        <ColumnDefinition Width="0.85*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource Panel}" Padding="16" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="70"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left" Text="{Binding StatusText}" Style="{StaticResource SectionTitle}" Margin="0,0,16,0"/>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <TextBlock Text="{Binding AccountedBytesText, StringFormat=Seen {0}}" Foreground="{StaticResource MutedBrush}" Margin="0,0,18,0"/>
                                    <TextBlock Text="{Binding UsedBytesText, StringFormat=Used {0}}" Foreground="{StaticResource MutedBrush}" Margin="0,0,18,0"/>
                                    <TextBlock Text="{Binding ScanThroughputText}" Foreground="{StaticResource MutedBrush}"/>
                                </StackPanel>
                            </DockPanel>
                            <ProgressBar Grid.Row="1" Height="11" Maximum="1" Value="{Binding ScanProgressValue, Mode=OneWay}" VerticalAlignment="Center"/>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding ScanProgressText}" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding ScanEtaText}" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding ScanGapText}" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                            <ItemsControl Grid.Row="3" ItemsSource="{Binding FiveMinuteFindings}" Margin="0,14,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource SurfaceLowBrush}"
                                                BorderBrush="{StaticResource LineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="5"
                                                Padding="9,7"
                                                Margin="0,0,8,0">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding Label}" Foreground="{StaticResource MutedBrush}" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                                    <Border DockPanel.Dock="Right" Background="{StaticResource AccentSoftBrush}" BorderBrush="{StaticResource AccentDarkBrush}" BorderThickness="1" CornerRadius="3" Padding="4,1">
                                                        <TextBlock Text="{Binding Lane}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
                                                    </Border>
                                                </DockPanel>
                                                <TextBlock Grid.Row="1" Text="{Binding Value}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Row="2" Text="{Binding Detail}" Foreground="{StaticResource MutedBrush}" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="180"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource Panel}" Margin="0,0,12,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Drives" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>
                                <ListBox Grid.Row="1"
                                         ItemsSource="{Binding Volumes}"
                                         SelectedItem="{Binding SelectedVolume}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="270" Margin="0,0,10,10" Background="{StaticResource SurfaceLowBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="10"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <DockPanel LastChildFill="False">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Status}" DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" Margin="8,0,0,0"/>
                                                    </DockPanel>
                                                    <ProgressBar Grid.Row="1" Height="7" Maximum="1" Value="{Binding UsedPercent, Mode=OneWay}" Margin="0,8,0,0"/>
                                                    <Grid Grid.Row="2" Margin="0,8,0,0">
                                                        <TextBlock Text="{Binding Used, StringFormat=Used {0}}" Foreground="{StaticResource MutedBrush}"/>
                                                        <TextBlock Text="{Binding Free, StringFormat=Free {0}}" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Right"/>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource Panel}" Margin="0,0,12,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Top space consumers" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding TopSpaceConsumers}" AlternationCount="2">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                                        <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="110"/>
                                        <DataGridTextColumn Header="%" Binding="{Binding Percent}" Width="80"/>
                                        <DataGridTextColumn Header="Type" Binding="{Binding Category}" Width="120"/>
                                        <DataGridTextColumn Header="Safety" Binding="{Binding Safety}" Width="120"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource Panel}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Cleanup potential" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>
                                <ItemsControl ItemsSource="{Binding CleanupPotential}" ItemTemplate="{StaticResource BreakdownTemplate}"/>
                                <Separator Margin="0,12"/>
                                <TextBlock Text="{Binding WarningSummary}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource Panel}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Top folders found so far" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>
                                <controls:TreemapView Grid.Row="1" ItemsSource="{Binding TreemapTiles}" TileSelectedCommand="{Binding TreemapTileSelectedCommand}"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="0"
                            Grid.RowSpan="2"
                            Grid.ColumnSpan="2"
                            Panel.ZIndex="20"
                            Visibility="{Binding IsFirstRunWelcomeVisible, Converter={StaticResource BoolToVisibility}}"
                            Background="{StaticResource AppBg}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="26">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.95*"/>
                                <ColumnDefinition Width="1.05*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="10,0,34,0">
                                <TextBlock Text="Disk Space Inspector" Foreground="{StaticResource TextPrimaryBrush}" FontSize="34" FontWeight="SemiBold"/>
                                <TextBlock Text="Find what is using disk space, understand why it exists, and review safe cleanup candidates before anything is touched."
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="16"
                                           TextWrapping="Wrap"
                                           Margin="0,12,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                                    <Button Content="Scan this PC"
                                            Command="{Binding ScanAllCommand}"
                                            Background="{StaticResource AccentBrush}"
                                            BorderBrush="{StaticResource AccentBrush}"
                                            Padding="18,10"/>
                                    <Button Content="Open demo workspace"
                                            Command="{Binding LoadDemoCommand}"
                                            Padding="18,10"/>
                                    <Button Content="Read cleanup safety"
                                            Command="{Binding ShowCleanupSafetyCommand}"
                                            Padding="18,10"/>
                                </StackPanel>
                                <Separator Margin="0,26"/>
                                <UniformGrid Rows="1">
                                    <StackPanel Margin="0,0,20,0">
                                        <TextBlock Text="No telemetry" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="Reports are local and path-redacted." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,20,0">
                                        <TextBlock Text="Staged cleanup" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="Recommendations are review-first." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Demo included" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="Try every visualizer without scanning real drives." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Background="{StaticResource SurfaceLowBrush}"
                                    BorderBrush="{StaticResource LineStrongBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <DockPanel>
                                        <TextBlock Text="First five minutes" Style="{StaticResource SectionTitle}"/>
                                        <Border DockPanel.Dock="Right" Background="{StaticResource AccentSoftBrush}" BorderBrush="{StaticResource AccentDarkBrush}" BorderThickness="1" CornerRadius="4" Padding="7,3">
                                            <TextBlock Text="stable release" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                        </Border>
                                    </DockPanel>
                                    <Grid Grid.Row="1" Margin="0,18,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="0.8*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="3" Background="#10201F" BorderBrush="{StaticResource AccentDarkBrush}" BorderThickness="1" CornerRadius="5" Padding="14" Margin="0,0,12,0">
                                            <StackPanel>
                                                <TextBlock Text="Visual Lab" Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" FontWeight="SemiBold"/>
                                                <TextBlock Text="28 deterministic charts turn a scan into space, time, ownership, risk, and cleanup evidence." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,8,0,16"/>
                                                <ProgressBar Height="9" Maximum="1" Value="0.78"/>
                                                <ProgressBar Height="9" Maximum="1" Value="0.54" Foreground="{StaticResource WarningBrush}" Margin="0,10,0,0"/>
                                                <ProgressBar Height="9" Maximum="1" Value="0.32" Foreground="{StaticResource DangerBrush}" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="0" Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="5" Padding="12" Margin="0,0,0,8">
                                            <TextBlock Text="Safe reclaimable space appears separately from review and blocked system paths." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="5" Padding="12" Margin="0,0,0,8">
                                            <TextBlock Text="Relationships explain cache ownership, package artifacts, cloud sync roots, and protected paths." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                        </Border>
                                        <Border Grid.Row="2" Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="5" Padding="12">
                                            <TextBlock Text="Cleanup advice is local, evidence-backed, and blocked paths stay protected." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Grid.Row="2" Text="Use demo mode for screenshots or a safe tour; scan this PC when you are ready for local results." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Explore">
                <Grid Background="{StaticResource AppBg}" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <TextBlock Text="{Binding Breadcrumb}" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <TextBlock Text="Min MB" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Width="74" Text="{Binding MinimumSizeMegabytes, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
                            <Button Content="Drill" Command="{Binding DrillIntoSelectionCommand}"/>
                            <Button Content="Open" Command="{Binding OpenSelectedCommand}"/>
                        </StackPanel>
                    </DockPanel>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="330"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource Panel}" Padding="0">
                            <TreeView ItemsSource="{Binding TreeNodes}"
                                      SelectedItemChanged="TreeView_OnSelectedItemChanged"
                                      Background="{StaticResource PanelBrush}"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      BorderThickness="0"
                                      Padding="10"/>
                        </Border>
                        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="5"/>
                                <RowDefinition Height="300"/>
                            </Grid.RowDefinitions>
                            <DataGrid x:Name="NodeGrid"
                                      ItemsSource="{Binding NodeRows}"
                                      SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                                      MouseDoubleClick="NodeGrid_OnMouseDoubleClick"
                                      AlternationCount="2">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                                    <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="110"/>
                                    <DataGridTextColumn Header="%" Binding="{Binding Percent}" Width="70"/>
                                    <DataGridTextColumn Header="Items" Binding="{Binding Items}" Width="150"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding Category}" Width="110"/>
                                    <DataGridTextColumn Header="Modified" Binding="{Binding Modified}" Width="145"/>
                                    <DataGridTextColumn Header="Safety" Binding="{Binding Safety}" Width="115"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"/>
                            <Border Grid.Row="2" Style="{StaticResource Panel}" Padding="0">
                                <controls:TreemapView ItemsSource="{Binding TreemapTiles}" TileSelectedCommand="{Binding TreemapTileSelectedCommand}"/>
                            </Border>
                        </Grid>
                        <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"/>
                        <Border Grid.Column="4" Style="{StaticResource Panel}">
                            <StackPanel>
                                <TextBlock Text="Selection" Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="{Binding SelectedName}" FontSize="20" FontWeight="SemiBold" Margin="0,14,0,4" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding SelectedPath}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                <Separator Margin="0,14"/>
                                <TextBlock Text="{Binding SelectedSize, StringFormat=Size: {0}}"/>
                                <TextBlock Text="{Binding SelectedCounts, StringFormat=Items: {0}}" Margin="0,8,0,0"/>
                                <Border Background="{StaticResource AccentSoftBrush}"
                                        BorderBrush="{StaticResource AccentDarkBrush}"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="9,7"
                                        Margin="0,14,0,0">
                                    <TextBlock Text="{Binding SelectedSafety}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </Border>
                                <Separator Margin="0,14"/>
                                <TextBlock Text="Evidence" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding EvidenceRelationships}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Evidence}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Visualize">
                <Grid Background="{StaticResource AppBg}" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="220"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="0.8*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource Panel}" Padding="0" Margin="0,0,12,12">
                        <Grid>
                            <TextBlock Text="Squarified treemap" Style="{StaticResource SectionTitle}" Margin="14" Panel.ZIndex="1"/>
                            <controls:TreemapView Margin="0,42,0,0" ItemsSource="{Binding TreemapTiles}" TileSelectedCommand="{Binding TreemapTileSelectedCommand}"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource Panel}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Sunburst" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>
                            <controls:SunburstView Grid.Row="1" ItemsSource="{Binding SunburstSegments}" SegmentSelectedCommand="{Binding SunburstSegmentSelectedCommand}"/>
                        </Grid>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource Panel}" Margin="0,0,12,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="File types" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>
                            <ItemsControl Grid.Row="1" ItemsSource="{Binding TypeBreakdown}" ItemTemplate="{StaticResource BreakdownTemplate}"/>
                        </Grid>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Panel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Age" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>
                            <ItemsControl Grid.Row="1" ItemsSource="{Binding AgeHistogram}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="92"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Label}" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <ProgressBar Grid.Column="1" Height="8" Maximum="1" Value="{Binding Fraction, Mode=OneWay}" Foreground="{StaticResource WarningBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Size}" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Visual Lab">
                <Grid Background="{StaticResource AppBg}" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="92"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource Panel}" Padding="14" Margin="0,0,0,12">
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left" Width="680">
                                <TextBlock Text="Visual Lab" Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="{Binding VisualLabSummary}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Background="{StaticResource AccentSoftBrush}" BorderBrush="{StaticResource AccentDarkBrush}" BorderThickness="1" CornerRadius="5" Padding="9,6" Margin="0,0,8,0">
                                    <TextBlock Text="Best insights first" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Border>
                                <Border Background="{StaticResource SurfaceLowBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="5" Padding="9,6">
                                    <TextBlock Text="Advanced algorithms hidden below" Foreground="{StaticResource MutedBrush}"/>
                                </Border>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="Best insights" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>
                            <ItemsControl ItemsSource="{Binding VisualLabCharts}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="400" MinHeight="338" Style="{StaticResource Panel}" Margin="0,0,12,12" Padding="13">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="116"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                                                    <Border Grid.Column="1" Background="{StaticResource SurfaceLowBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="4" Padding="6,2">
                                                        <TextBlock Text="{Binding Group}" FontSize="10.5" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis"/>
                                                    </Border>
                                                </Grid>
                                                <controls:AnalyticsChartView Grid.Row="1"
                                                                             Chart="{Binding Definition}"
                                                                             ChartSelectedCommand="{Binding DataContext.VisualChartSelectedCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                                             Height="220"
                                                                             Margin="0,11,0,10"/>
                                                <TextBlock Grid.Row="2" Text="{Binding Insight}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" LineHeight="15"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Expander Header="Advanced algorithms" IsExpanded="False" Margin="0,8,0,0">
                                <ItemsControl ItemsSource="{Binding VisualLabAdvancedCharts}" Margin="0,12,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="400" MinHeight="338" Style="{StaticResource Panel}" Margin="0,0,12,12" Padding="13">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="116"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                                                        <Border Grid.Column="1" Background="{StaticResource SurfaceLowBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="4" Padding="6,2">
                                                            <TextBlock Text="{Binding Kind}" FontSize="10.5" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis"/>
                                                        </Border>
                                                    </Grid>
                                                    <controls:AnalyticsChartView Grid.Row="1"
                                                                                 Chart="{Binding Definition}"
                                                                                 ChartSelectedCommand="{Binding DataContext.VisualChartSelectedCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                                                 Height="220"
                                                                                 Margin="0,11,0,10"/>
                                                    <TextBlock Grid.Row="2" Text="{Binding Description}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" LineHeight="15"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Cleanup">
                <Grid Background="{StaticResource AppBg}" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="190"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource Panel}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="False" Margin="0,0,0,10">
                                <StackPanel DockPanel.Dock="Left" Width="560">
                                    <TextBlock Text="Local cleanup advisor" Style="{StaticResource SectionTitle}"/>
                                    <TextBlock Text="{Binding LocalAdvisorStatusText}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <TextBlock Text="{Binding PlannedCleanupSize, StringFormat=Staged: {0}}" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <Button Content="Stage selected" Command="{Binding StageFindingCommand}" Background="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"/>
                                    <Button Content="Safety center" Command="{Binding OpenPrivacyCenterCommand}"/>
                                </StackPanel>
                            </DockPanel>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.3*"/>
                                    <ColumnDefinition Width="0.7*"/>
                                </Grid.ColumnDefinitions>
                                <ItemsControl ItemsSource="{Binding CleanupPotential}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource SurfaceLowBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,8,0">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="8"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding Label}" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                    <ProgressBar Grid.Row="1" Height="7" Maximum="1" Value="{Binding Fraction, Mode=OneWay}" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Row="2" Text="{Binding Size}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Grid.Column="1" Background="{StaticResource SurfaceLowBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="5" Padding="12" Margin="10,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Guardrails" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="Safe items can be staged for review. Review items need human context. System cleanup uses official routes. Blocked paths are explanation-only."
                                                   Foreground="{StaticResource MutedBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,7,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource Panel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="False" Margin="0,0,0,10">
                                <TextBlock Text="Cleanup findings" Style="{StaticResource SectionTitle}"/>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <TextBlock Text="{Binding PlannedCleanupSize, StringFormat=Staged: {0}}" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <Button Content="Stage selected" Command="{Binding StageFindingCommand}" Background="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </DockPanel>
                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding CleanupFindings}"
                                      SelectedItem="{Binding SelectedFinding, Mode=TwoWay}"
                                      AlternationCount="2">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Item" Binding="{Binding DisplayName}" Width="2*"/>
                                    <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="110"/>
                                    <DataGridTextColumn Header="Safety" Binding="{Binding Safety}" Width="155"/>
                                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="150"/>
                                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="160"/>
                                    <DataGridTextColumn Header="Confidence" Binding="{Binding Confidence}" Width="100"/>
                                    <DataGridTextColumn Header="Why" Binding="{Binding Explanation}" Width="4*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Changes">
                <Grid Background="{StaticResource AppBg}" Margin="16">
                    <Border Style="{StaticResource Panel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="What changed" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding Changes}" AlternationCount="2">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="100"/>
                                    <DataGridTextColumn Header="Direction" Binding="{Binding Direction}" Width="100"/>
                                    <DataGridTextColumn Header="Delta" Binding="{Binding Delta}" Width="110"/>
                                    <DataGridTextColumn Header="Current" Binding="{Binding CurrentSize}" Width="110"/>
                                    <DataGridTextColumn Header="Previous" Binding="{Binding PreviousSize}" Width="110"/>
                                    <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="3*"/>
                                    <DataGridTextColumn Header="Previous path" Binding="{Binding PreviousPath}" Width="2*"/>
                                    <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="2*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Insights">
                <Grid Background="{StaticResource AppBg}" Margin="16">
                    <Border Style="{StaticResource Panel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Storage insights and relationships" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding Insights}" AlternationCount="2">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tool" Binding="{Binding Tool}" Width="180"/>
                                    <DataGridTextColumn Header="Finding" Binding="{Binding Title}" Width="220"/>
                                    <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="110"/>
                                    <DataGridTextColumn Header="Safety" Binding="{Binding Safety}" Width="120"/>
                                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="140"/>
                                    <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="2*"/>
                                    <DataGridTextColumn Header="Why" Binding="{Binding Description}" Width="3*"/>
                                    <DataGridTextColumn Header="Evidence" Binding="{Binding Evidence}" Width="2*"/>
                                    <DataGridTextColumn Header="Confidence" Binding="{Binding Confidence}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Tutorials">
                <Grid Background="{StaticResource AppBg}" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="72"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource Panel}" Padding="14" Margin="0,0,0,12">
                        <DockPanel LastChildFill="False">
                            <StackPanel Width="620">
                                <TextBlock Text="Guided workflows" Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="Short practical flows for scanning, reading charts, staging cleanup, relationships, privacy, and safe demo mode." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                            </StackPanel>
                            <Border DockPanel.Dock="Right" Background="{StaticResource SurfaceLowBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="5" Padding="9,6" VerticalAlignment="Center">
                                <TextBlock Text="Cleanup stays advisory and staged" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Border>
                        </DockPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TutorialSteps}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="390" MinHeight="210" Style="{StaticResource Panel}" Margin="0,0,12,12" Padding="14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="52"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="38" Height="38" Background="{StaticResource AccentSoftBrush}" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" CornerRadius="19" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding NumberText}" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Goal}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,10"/>
                                                <TextBlock Text="{Binding Body}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                                <Separator Margin="0,12"/>
                                                <TextBlock Text="{Binding Action}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding SafetyNote}" Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <Grid Background="{StaticResource AppBg}" Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.95*"/>
                        <ColumnDefinition Width="1.05*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource Panel}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Privacy &amp; Safety Center" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="Disk Space Inspector is built for local storage analysis. It does not send telemetry, does not use external advisor services, and keeps cleanup advisory in this release."
                                       Foreground="{StaticResource MutedBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0"/>
                            <Separator Margin="0,16"/>
                            <ItemsControl ItemsSource="{Binding PrivacyFacts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource SurfaceLowBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="5" Padding="11" Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Label}" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Value}" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Detail}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="Blocked direct cleanup paths" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                            <TextBlock Text="{Binding BlockedDirectCleanupPaths}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Panel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left" Width="520">
                                    <TextBlock Text="Local diagnostics export" Style="{StaticResource SectionTitle}"/>
                                    <TextBlock Text="Creates a local Markdown and JSON bundle for bug reports or support. Paths are redacted to %USERPROFILE% by default."
                                               Foreground="{StaticResource MutedBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="Export diagnostics"
                                        Command="{Binding ExportDiagnosticsCommand}"
                                        Background="{StaticResource AccentBrush}"
                                        BorderBrush="{StaticResource AccentBrush}"
                                        VerticalAlignment="Top"/>
                            </DockPanel>
                            <Border Grid.Row="1" Background="{StaticResource SurfaceLowBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="5" Padding="12" Margin="0,16,0,16">
                                <StackPanel>
                                    <TextBlock Text="{Binding ReportExportStatus}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding ReportsDirectory, StringFormat=Reports: {0}}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding DatabasePath, StringFormat=Database: {0}}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Border Background="{StaticResource SurfaceLowBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="5" Padding="14" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Release posture" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="This stable build is unsigned. Windows SmartScreen may warn until the app gains reputation or code signing is added." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="{StaticResource SurfaceLowBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="5" Padding="14" Margin="8,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Current scan" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding ScanDetail}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="{StaticResource RailBg}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding ScanDetail}" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="18,0"/>
        </Border>
    </Grid>
</Window>
